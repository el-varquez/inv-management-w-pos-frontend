# Vite env vars must be prefixed with VITE_ to be exposed to the client bundle.
# They are baked into the build at build time and shipped to the browser, so
# they are NOT secret — never put real secrets here.
#
# Local development reads .env.development (committed) and points at the local
# API on http://localhost:5103/api.
#
# For production, set VITE_API_URL to your deployed backend, for example:
#   VITE_API_URL=https://your-backend.onrender.com/api
# Provide it via your deploy host's build-time environment variables, or create
# a gitignored .env.production.local for a one-off local production build.

VITE_API_URL=http://localhost:5103/api
